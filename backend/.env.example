# CalDAV server credentials
# iCloud:     https://caldav.icloud.com
# Fastmail:   https://caldav.fastmail.com/
# Nextcloud:  https://your-domain.com/remote.php/dav/
# Google Cal: https://www.google.com/calendar/dav/YOUR_EMAIL/events/
CALDAV_URL=https://caldav.example.com
CALDAV_USERNAME=you@example.com
CALDAV_PASSWORD=your_app_password
# Leave empty to use the first/default calendar
CALDAV_CALENDAR_NAME=

# Optional: change this if your frontend runs on a different port
FRONTEND_URL=http://localhost:3000
